# Πόρτα του server
PORT=3000

# Public URL του server (αυτό μπαίνει στο QR code)
# Παράδειγμα: https://barbershop.example.com  ή  http://192.168.1.5:3000
PUBLIC_URL=http://localhost:3000

# Κωδικός για τη σελίδα διαχείρισης (admin) — DEPRECATED
# Στη νέα έκδοση κάθε κουρείο έχει δικό του κωδικό μέσω signup.
# Διατηρείται για backwards compat κατά την ανάπτυξη.
ADMIN_PASSWORD=changeme

# Super-admin (marketplace owner) — σε plain ή σε bcrypt hash
# Πρόσφερε ΕΝΑ από τα δύο. Hash είναι ασφαλέστερο.
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_PASSWORD_HASH=

# JWT secret για sessions — βάλε ΣΤΑΘΕΡΟ random string (>=32 χαρακτήρες) σε παραγωγή
# Ξεκινήστε με: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# CORS: επιτρεπόμενα origins (comma-separated). Άφησε κενό για same-origin only.
CORS_ALLOWED_ORIGINS=

# Καταγραφή PII σε console (test mode SMS/email)
# Σε production βάλτο "false" για να μη φαίνονται phone numbers στα logs
LOG_PII=true

# Ώρες λειτουργίας
OPEN_HOUR=09
CLOSE_HOUR=20
SLOT_MINUTES=30

# Όνομα κομμωτηρίου (εμφανίζεται στη φόρμα και στα SMS)
SHOP_NAME=Το Κουρείο μου

# Twilio credentials για αποστολή SMS
# Άφησέ τα κενά αν θέλεις να τυπώνονται μόνο στην κονσόλα (test mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP για επιβεβαιωτικά email
# Άφησέ τα κενά αν θέλεις να τυπώνονται μόνο στην κονσόλα (test mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Το Κουρείο μου <noreply@example.com>"
