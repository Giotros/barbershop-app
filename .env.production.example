# ===========================================
# Production environment template για Render.com
# ===========================================
# Αντίγραψε αυτές τις τιμές στα Environment Variables του Render service.
# ΜΗΝ τις βάλεις σε αρχείο που ανεβαίνει στο GitHub.

# ---- ΥΠΟΧΡΕΩΤΙΚΑ ----

# JWT secret (έτοιμο, παραγωγής, μοναδικό για εσένα — μη το μοιραστείς)
JWT_SECRET=06d720aa36b565a0e0c167c405c797f21c9cac6366f207246a35b706feeb6e26

# Super-admin password (marketplace owner) — ΔΙΚΟΣ ΣΟΥ ισχυρός κωδικός
# Άλλαξέ τον σε κάτι μοναδικό 12+ χαρακτήρες
SUPER_ADMIN_PASSWORD=ΑΛΛΑΞΕ-ΜΕ-ΣΕ-ΙΣΧΥΡΟ-ΚΩΔΙΚΟ

# Public URL του deployment — ενημέρωσε όταν πάρεις το URL από Render
PUBLIC_URL=https://barberhub-XXXX.onrender.com

# Όνομα εφαρμογής
APP_NAME=Barberhub

# ---- DATA / LOGGING ----

# Βάση δεδομένων στο persistent disk
DB_PATH=/data/barbershop.db

# Don't log PII σε production
LOG_PII=false

NODE_ENV=production

# ---- ΩΡΑΡΙΑ (defaults για νέους κουρείς) ----
OPEN_HOUR=09
CLOSE_HOUR=20
SLOT_MINUTES=30

# ---- TWILIO (SMS) ----
# Φτιάξε λογαριασμό σε twilio.com, πάρε νούμερο, και αντιγράψε εδώ:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- EMAIL (Gmail SMTP) ----
# Ενεργοποίησε 2FA στο Gmail, φτιάξε App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Barberhub <noreply@example.com>

# ---- GOOGLE PLACES API (προαιρετικό, για reviews) ----
GOOGLE_API_KEY=

# ---- DEPRECATED ----
# Άφησέ το κενό σε production για να μη δουλεύει το παλιό auth bypass
ADMIN_PASSWORD=
